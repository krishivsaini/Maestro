# --- Maestro environment ---
# Copy to `.env` and fill in. Never commit `.env`.

# Gemini free tier (primary LLM). Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional web-search provider key (only if using a keyed provider such as Tavily/SerpAPI).
# The default provider is DuckDuckGo, which needs no key.
SEARCH_API_KEY=

# --- Optional overrides (defaults live in maestro/config.py) ---
# All Maestro settings can be overridden with the MAESTRO_ prefix, e.g.:
# MAESTRO_MODEL_ID=gemini-3.5-flash
# MAESTRO_MAX_PARALLEL=2
# MAESTRO_MAX_CRITIC_ITERS=3
# MAESTRO_FAULT_INJECTION=false          # set true to demo visible recovery
# MAESTRO_FAULT_INJECTION_TOOL=web_search
